<Window x:Class="PowerliftingIS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PowerliftingIS"
        mc:Ignorable="d"
        Title="Система управления секцией пауэрлифтинга"
        Height="620" Width="1000"
        MinHeight="620" MinWidth="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- САЙДБАР -->
        <Border Grid.Column="0"
                Background="{StaticResource BgSidebar}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Логотип -->
                <Border Grid.Row="0"
                        Style="{StaticResource LogoPanel}">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource LogoText}"
                                   Text="⚡ POWERLIFTING"/>
                        <TextBlock Style="{StaticResource LogoText}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextMuted}"
                                   Text="MANAGEMENT SYSTEM"
                                   Margin="0 2 0 0"/>
                    </StackPanel>
                </Border>

                <!-- Акцентная черта -->
                <Border Grid.Row="1"
                        Style="{StaticResource LogoAccentBar}"/>

                <!-- Кнопки меню -->
                <StackPanel Grid.Row="2">

                    <TextBlock Style="{StaticResource MenuSectionLabel}"
                               Text="ОСНОВНОЕ"/>

                    <Button x:Name="AthleteBtn"
                            Style="{StaticResource MenuButton}"
                            Content="👤  Спортсмены"
                            Click="AthleteBtn_Click"/>

                    <Button x:Name="TrainingBtn"
                            Style="{StaticResource MenuButton}"
                            Content="🏋  Тренировки"
                            Click="TrainingBtn_Click"/>

                    <Button x:Name="ResultBtn"
                            Style="{StaticResource MenuButton}"
                            Content="🏆  Результаты"
                            Click="ResultBtn_Click"/>

                    <TextBlock Style="{StaticResource MenuSectionLabel}"
                               Text="АНАЛИТИКА"/>

                    <Button x:Name="ReportBtn"
                            Style="{StaticResource MenuButton}"
                            Content="📊  Отчёт"
                            Click="ReportBtn_Click"/>

                </StackPanel>

                <!-- Нижняя часть: тренер + выход -->
                <Border Grid.Row="3"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="0 1 0 0"
                        Margin="0 0 0 0">
                    <Grid Margin="14 12 14 12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock x:Name="CoachNameTb"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="CoachRoleTb"
                                       FontSize="11"
                                       Foreground="{StaticResource Accent}"
                                       Margin="0 2 0 0"/>
                        </StackPanel>

                        <Button Grid.Row="2"
                                Style="{StaticResource MenuExitButton}"
                                Content="⏻  Выйти из системы"
                                HorizontalContentAlignment="Left"
                                Click="ExitBtn_Click"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- КОНТЕНТ -->
        <Border Grid.Column="1"
                Background="{StaticResource BgDeep}">
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"/>
        </Border>

    </Grid>
</Window>

