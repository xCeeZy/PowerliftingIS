<Page x:Class="PowerliftingIS.View.Pages.ResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PowerliftingIS.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="{StaticResource BgDeep}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Style="{StaticResource PageTitle}"
                   Text="Результаты"/>

        <Border Grid.Row="1"
                Style="{StaticResource TitleAccentBar}"/>

        <!-- Панель фильтров -->
        <Grid Grid.Row="2"
              Margin="0 0 0 14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal">
                <ComboBox x:Name="AthleteFilterCb"
                          Background="#1E2A4A" Foreground="#EAEAEA" BorderBrush="#1E3060" BorderThickness="1" Height="36" FontSize="13"
                          Width="200"
                          Margin="0 0 10 0"
                          SelectionChanged="FilterChanged"/>

                <ComboBox x:Name="ExerciseFilterCb"
                          Background="#1E2A4A" Foreground="#EAEAEA" BorderBrush="#1E3060" BorderThickness="1" Height="36" FontSize="13"
                          Width="170"
                          Margin="0 0 10 0"
                          SelectionChanged="FilterChanged"/>

                <ComboBox x:Name="RecordFilterCb"
                          Background="#1E2A4A" Foreground="#EAEAEA" BorderBrush="#1E3060" BorderThickness="1" Height="36" FontSize="13"
                          Width="160"
                          SelectionChanged="FilterChanged"/>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Style="{StaticResource PrimaryButton}"
                        Content="+ Добавить"
                        Width="120"
                        Margin="0 0 10 0"
                        Click="AddBtn_Click"/>
                <Button Style="{StaticResource DangerButton}"
                        Content="Удалить"
                        Width="100"
                        Click="DeleteBtn_Click"/>
            </StackPanel>
        </Grid>

        <!-- Таблица результатов -->
        <DataGrid Grid.Row="3"
                  x:Name="ResultsDg"
                  Style="{StaticResource MainDataGrid}"
                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата"
                                    Binding="{Binding ResultDate, StringFormat='dd.MM.yyyy'}"
                                    Width="90"/>
                <DataGridTextColumn Header="Спортсмен"
                                    Binding="{Binding Athletes.FullName}"
                                    Width="2*"/>
                <DataGridTextColumn Header="Упражнение"
                                    Binding="{Binding Exercises.ExerciseName}"
                                    Width="*"/>
                <DataGridTextColumn Header="Вес (кг)"
                                    Binding="{Binding ResultWeight}"
                                    Width="80"/>
                <DataGridTextColumn Header="Соревнование"
                                    Binding="{Binding Competitions.CompetitionName}"
                                    Width="2*"/>
                <DataGridCheckBoxColumn Header="Рекорд"
                                        Binding="{Binding IsPersonalRecord}"
                                        Width="70"/>
                <DataGridTextColumn Header="Примечание"
                                    Binding="{Binding Note}"
                                    Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Page>


