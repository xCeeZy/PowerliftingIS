<Page x:Class="PowerliftingIS.View.Pages.ReportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PowerliftingIS.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Background="{StaticResource BgDeep}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Style="{StaticResource PageTitle}"
                   Text="Отчёт"/>

        <Border Grid.Row="1"
                Style="{StaticResource TitleAccentBar}"/>

        <!-- Фильтры -->
        <Grid Grid.Row="2"
              Margin="0 0 0 14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0"
                      x:Name="RankFilterCb"
                      Background="#1E2A4A" Foreground="#EAEAEA" BorderBrush="#1E3060" BorderThickness="1" Height="36" FontSize="13"
                      Width="160"
                      SelectionChanged="FilterChanged"/>

            <DatePicker Grid.Column="2"
                        x:Name="DateFromDp"
                        Background="#1E2A4A" Foreground="#EAEAEA" BorderBrush="#1E3060" BorderThickness="1" Height="36" FontSize="13"
                        Width="140"
                        SelectedDateChanged="FilterChanged"/>

            <DatePicker Grid.Column="4"
                        x:Name="DateToDp"
                        Background="#1E2A4A" Foreground="#EAEAEA" BorderBrush="#1E3060" BorderThickness="1" Height="36" FontSize="13"
                        Width="140"
                        SelectedDateChanged="FilterChanged"/>

            <Button Grid.Column="6"
                    Style="{StaticResource PrimaryButton}"
                    Content="Сформировать"
                    Width="140"
                    Click="BuildBtn_Click"/>
        </Grid>

        <!-- Плитки статистики -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock x:Name="TotalAthletesTb"
                               Style="{StaticResource StatNumber}"
                               Text="0"/>
                    <TextBlock Style="{StaticResource StatLabel}"
                               Text="СПОРТСМЕНОВ"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock x:Name="TotalTrainingsTb"
                               Style="{StaticResource StatNumber}"
                               Text="0"/>
                    <TextBlock Style="{StaticResource StatLabel}"
                               Text="ТРЕНИРОВОК"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock x:Name="TotalRecordsTb"
                               Style="{StaticResource StatNumberGreen}"
                               Text="0"/>
                    <TextBlock Style="{StaticResource StatLabel}"
                               Text="ЛИЧНЫХ РЕКОРДОВ"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock x:Name="BestResultTb"
                               Style="{StaticResource StatNumber}"
                               Text="—"/>
                    <TextBlock Style="{StaticResource StatLabel}"
                               Text="МАКС. ВЕС (КГ)"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Таблица сводки по спортсменам -->
        <DataGrid Grid.Row="5"
                  x:Name="ReportDg"
                  Style="{StaticResource MainDataGrid}"
                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Спортсмен"
                                    Binding="{Binding AthleteName}"
                                    Width="2*"/>
                <DataGridTextColumn Header="Разряд"
                                    Binding="{Binding RankName}"
                                    Width="*"/>
                <DataGridTextColumn Header="Тренировок"
                                    Binding="{Binding TrainingCount}"
                                    Width="90"/>
                <DataGridTextColumn Header="Лучший присед"
                                    Binding="{Binding BestSquat}"
                                    Width="110"/>
                <DataGridTextColumn Header="Лучший жим"
                                    Binding="{Binding BestBench}"
                                    Width="100"/>
                <DataGridTextColumn Header="Лучшая тяга"
                                    Binding="{Binding BestDeadlift}"
                                    Width="100"/>
                <DataGridTextColumn Header="Рекордов"
                                    Binding="{Binding RecordsCount}"
                                    Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Page>

