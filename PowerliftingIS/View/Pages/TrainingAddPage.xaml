<Page x:Class="PowerliftingIS.View.Pages.TrainingAddPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PowerliftingIS.View.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
     Background="{StaticResource BgDeep}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Style="{StaticResource PageTitle}"
                   Text="Добавить тренировку"/>

        <Border Grid.Row="1"
                Style="{StaticResource TitleAccentBar}"/>

        <Border Grid.Row="2"
                Style="{StaticResource Card}"
                VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="160"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Дата -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Style="{StaticResource FieldLabel}"
                           Text="ДАТА ТРЕНИРОВКИ"/>
                <DatePicker Grid.Row="2" Grid.Column="0"
                            x:Name="TrainingDateDp"
                            Background="#1E2A4A" Foreground="#EAEAEA" BorderBrush="#1E3060" BorderThickness="1" Height="36" FontSize="13"/>

                <!-- Тренер -->
                <TextBlock Grid.Row="0" Grid.Column="2"
                           Style="{StaticResource FieldLabel}"
                           Text="ТРЕНЕР"/>
                <ComboBox Grid.Row="2" Grid.Column="2"
                          x:Name="CoachCb"
                          Background="#1E2A4A" Foreground="#EAEAEA" BorderBrush="#1E3060" BorderThickness="1" Height="36" FontSize="13"
                          SelectionChanged="CoachCb_SelectionChanged"/>

                <!-- Описание -->
                <TextBlock Grid.Row="4" Grid.Column="0"
                           Grid.ColumnSpan="3"
                           Style="{StaticResource FieldLabel}"
                           Text="ОПИСАНИЕ ТРЕНИРОВКИ"/>
                <TextBox Grid.Row="6" Grid.Column="0"
                         Grid.ColumnSpan="3"
                         x:Name="DescriptionTb"
                         Style="{StaticResource InputTextBox}"
                         Height="Auto"
                         MinHeight="36"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"/>

                <!-- Спортсмены тренера -->
                <TextBlock Grid.Row="8" Grid.Column="0"
                           Grid.ColumnSpan="3"
                           Style="{StaticResource FieldLabel}"
                           Text="СПОРТСМЕНЫ ТРЕНЕРА (выберите присутствовавших)"/>

                <ListBox Grid.Row="10" Grid.Column="0"
                         Grid.ColumnSpan="3"
                         x:Name="AthletesLb"
                         Background="{StaticResource BgInput}"
                         BorderBrush="{StaticResource BorderSubtle}"
                         BorderThickness="1"
                         Foreground="{StaticResource TextPrimary}"
                         FontSize="13"
                         SelectionMode="Multiple"/>

                <!-- Все спортсмены (если тренер не выбран) -->
                <TextBlock Grid.Row="12" Grid.Column="0"
                           Grid.ColumnSpan="3"
                           Style="{StaticResource FieldLabel}"
                           Text="ВСЕ СПОРТСМЕНЫ (дополнительно)"/>

                <ListBox Grid.Row="14" Grid.Column="0"
                         Grid.ColumnSpan="3"
                         x:Name="AllAthletesLb"
                         Background="{StaticResource BgInput}"
                         BorderBrush="{StaticResource BorderSubtle}"
                         BorderThickness="1"
                         Foreground="{StaticResource TextPrimary}"
                         FontSize="13"
                         SelectionMode="Multiple"/>

                <!-- Разделитель -->
                <Border Grid.Row="16" Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Height="1"
                        Background="{StaticResource BorderSubtle}"/>

                <!-- Кнопки -->
                <StackPanel Grid.Row="18" Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="Назад"
                            Width="110"
                            Margin="0 0 10 0"
                            Click="BackBtn_Click"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Сохранить"
                            Width="130"
                            Click="SaveBtn_Click"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</Page>



